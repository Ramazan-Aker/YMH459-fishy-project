  m_Script: {fileID: 11500000, guid: 00000000000000000000000000000000, type: 3}
  m_Name: Surgeonfish_Data
  m_EditorClassIdentifier: FishMuseum.Data.FishData
  displayName: "Cerrah Balığı (Mavi Tang)"
  scientificName: "Paracanthurus hepatus"
  habitat: "Hint-Pasifik ve Kızıldeniz, mercan resifleri (2–40 m derinlik)"
  diet: "Herbivor – esas olarak fitoplankton ve alg tabanlı beslenme"
  summary: "Regal tang ya da Mavi Tang olarak da bilinen Cerrah Balığı, parlak mavi rengi, sarı kuyruk yüzgeci ve siyah palet deseniyle kolayca tanınır. Kuyruk sapındaki keskin dikensi uzantısı (skalpel benzeri) ona 'cerrah' adını kazandırmıştır; tehdit altında bu yapıyı savunma aracı olarak kullanır. Mercan resiflerinin sağlığı için kritik önem taşır; aşırı alg büyümesini kontrol eder."
  menuIcon: {fileID: 0}
  prefab: {fileID: 0}
  narrationClip: {fileID: 0}
  parts:
  - partName: "Dorsal Yüzgeci"
    infoText: "Sırt yüzgeci uzun ve süreklidir; yüzme stabilitesini sağlar. 26–28 yumuşak ışından oluşur."
    childObjectName: "Part_DorsalFin"
    tooltipOffset: {x: 0, y: 0.1, z: 0}
  - partName: "Skalpel Diken"
    infoText: "Kuyruk sapındaki keskin kemik uzantısı (caudal spine), savunma amaçlı kullanılır. Dokunmak tehlikeli olabilir!"
    childObjectName: "Part_CaudalSpine"
    tooltipOffset: {x: -0.05, y: 0.03, z: 0}
  - partName: "Göz"
    infoText: "Geniş görüş alanı sunan büyük gözler, yırtıcıları erkenden fark etmeyi sağlar. Iris sarımsı tonlardadır."
    childObjectName: "Part_Eye"
    tooltipOffset: {x: 0.04, y: 0.05, z: 0.05}
  - partName: "Pektoral Yüzgeç"
    infoText: "Göğüs yüzgeci (pectoral fin) manevra ve hız için kullanılır. Mavi Tang bu yüzgeçleri kanat gibi çırparak hızlıca yön değiştirir."
    childObjectName: "Part_PectoralFin"
    tooltipOffset: {x: 0.02, y: 0, z: 0.06}
